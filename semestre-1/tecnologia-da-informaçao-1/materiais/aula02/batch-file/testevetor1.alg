algoritmo "semnome"
// Função :
// Autor :
// Data : 30/05/2017
// Seção de Declarações 
var
i: inteiro
x: vetor[1..10] de inteiro
inicio

 Escreval("Teste com Vetores")

 para i de 1 ate 10 faca
   Escreva("Informe um valor: ")
   leia(x[i])
 fimpara
 Escreval("Valores digitados")
 para i de 1 ate 10 faca
   Escreva("Posição: ", i)
   Escreval(x[i])
 fimpara

fimalgoritmo
